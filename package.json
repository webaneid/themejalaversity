{
  "name": "jalaversity",
  "version": "1.0.0",
  "description": "Jalaversity WordPress Theme — build pipeline",
  "private": true,
  "scripts": {
    "build": "npm run build:front && npm run build:admin",
    "build:front": "NODE_ENV=production postcss scss/front/main.scss -o css/front.css",
    "build:admin": "NODE_ENV=production postcss scss/admin/main.scss -o css/admin.css",
    "dev": "postcss scss/front/main.scss -o css/front.css --watch",
    "dev:admin": "postcss scss/admin/main.scss -o css/admin.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "cssnano": "^7.0.0",
    "postcss": "^8.4.0",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.1",
    "postcss-mixins": "^10.0.0",
    "postcss-nested": "^6.0.1",
    "postcss-scss": "^4.0.9",
    "tailwindcss": "^3.4.0"
  }
}
